{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "",
    "HangfireConnection": ""
  },
  "MongoDbSettings": {
    "ConnectionString": "",
    "DatabaseName": "UniThesisLogs"
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "UniThesis.API",
    "Audience": "UniThesis.Client",
    "ExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "EmailSettings": {
    "SmtpServer": "",
    "SmtpPort": 0,
    "SenderName": "UniThesis System",
    "SenderEmail": "",
    "Username": "",
    "Password": "",
    "EnableSsl": true
  },
  "FileStorageSettings": {
    "BasePath": "wwwroot/uploads",
    "MaxFileSizeInMB": 50,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".zip",
      ".rar",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  },
  "CacheSettings": {
    "DefaultExpirationInMinutes": 30,
    "SlidingExpirationInMinutes": 10
  },
  "Cors": {
    "AllowedOrigins": ["", ""]
  }
}
