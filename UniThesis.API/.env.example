# UniThesis API - Example environment file
# Copy this to ".env.Development" (or ".env") and fill in values.

ASPNETCORE_ENVIRONMENT=Development

# Database
Database__AutoMigrateOnStartup=true

# SQL Server
ConnectionStrings__DefaultConnection=Server=YOUR_SERVER;Database=YOUR_DB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true
ConnectionStrings__HangfireConnection=Server=YOUR_SERVER;Database=YOUR_HANGFIRE_DB;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true

# MongoDB
MongoDbSettings__ConnectionString=mongodb://localhost:27017
MongoDbSettings__DatabaseName=UniThesisLogs

# JWT (replace secret with a strong value in production)
JwtSettings__Secret=REPLACE_WITH_A_STRONG_SECRET
JwtSettings__Issuer=UniThesis.API
JwtSettings__Audience=UniThesis.Client
JwtSettings__ExpirationInMinutes=60
JwtSettings__RefreshTokenExpirationInDays=7

# CORS
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:3000

# Firebase
Firebase__ProjectId=your-firebase-project-id
Firebase__ServiceAccountKeyPath=service-account.json
Firebase__UseEmulator=true
Firebase__EmulatorHost=localhost:9099

# Firebase Storage
FirebaseStorage__BucketName=your-bucket-name
FirebaseStorage__MaxFileSizeBytes=52428800
FirebaseStorage__SignedUrlExpirationMinutes=60
FirebaseStorage__MakePublicByDefault=true

# Cache
CacheSettings__Provider=Hybrid
CacheSettings__DefaultExpirationInMinutes=30
CacheSettings__RedisConnectionString=localhost:6379,abortConnect=false
CacheSettings__L1ExpirationMinutes=2
CacheSettings__L2ExpirationMinutes=15
CacheSettings__InvalidationChannel=cache:invalidate

# Email (leave blank to configure)
EmailSettings__SmtpServer=
EmailSettings__SmtpPort=0
EmailSettings__SenderName=UniThesis System
EmailSettings__SenderEmail=
EmailSettings__Username=
EmailSettings__Password=
EmailSettings__EnableSsl=true

# Safety switch for load-test seeder reset
UNITHESIS_RESET_LOADTEST_ON_STARTUP=false

# Malware scanning (set Enabled=false in dev if ClamAV is not running locally)
Security__MalwareScan__Enabled=true
Security__MalwareScan__FailClosed=true
Security__MalwareScan__ClamAvHost=127.0.0.1
Security__MalwareScan__ClamAvPort=3310
