# UniThesis API environment variables
# Copy this file to .env or .env.Production and fill real values.

# Runtime
ASPNETCORE_ENVIRONMENT=Production

# SQL Server
ConnectionStrings__DefaultConnection=Server=localhost;Database=UniThesis;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True
ConnectionStrings__HangfireConnection=Server=localhost;Database=UniThesis;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True

# MongoDB
MongoDbSettings__ConnectionString=mongodb://localhost:27017
MongoDbSettings__DatabaseName=UniThesisLogs

# JWT
JwtSettings__Secret=replace-with-long-random-secret-at-least-32-chars
JwtSettings__Issuer=UniThesis.API
JwtSettings__Audience=UniThesis.Client
JwtSettings__ExpirationInMinutes=60
JwtSettings__RefreshTokenExpirationInDays=7

# Email
EmailSettings__SmtpServer=smtp.example.com
EmailSettings__SmtpPort=587
EmailSettings__SenderName=UniThesis System
EmailSettings__SenderEmail=no-reply@example.com
EmailSettings__Username=no-reply@example.com
EmailSettings__Password=replace-with-email-password
EmailSettings__EnableSsl=true

# Redis/Hybrid cache
CacheSettings__Provider=Hybrid
CacheSettings__RedisConnectionString=localhost:6379
CacheSettings__L1ExpirationMinutes=2
CacheSettings__L2ExpirationMinutes=15
CacheSettings__InvalidationChannel=cache:invalidate

# CORS
Cors__AllowedOrigins__0=https://your-frontend-domain.com
Cors__AllowedOrigins__1=https://admin.your-frontend-domain.com

# Firebase Storage
FirebaseStorage__BucketName=your-project.firebasestorage.app
FirebaseStorage__MaxFileSizeBytes=52428800
FirebaseStorage__SignedUrlExpirationMinutes=60
FirebaseStorage__MakePublicByDefault=true

# Safety: keep reset OFF in production
UNITHESIS_RESET_LOADTEST_ON_STARTUP=false
